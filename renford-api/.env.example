NODE_ENV=development
PORT=3000
CORS_ORIGIN=*
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/renford
JWT_SECRET=your-secret-key

EMAIL_SERVICE=Gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=notifications@renford.store
EMAIL_HOST_PASSWORD=
RESEND_API_KEY=

PLATFORM_URL=https://test.renford.store

# Odoo SMS (email equivalent notifications)
ODOO_SMS_ENABLED=false
ODOO_SMS_SENDER=Renford
ODOO_SMS_MAX_LENGTH=320

# Option A: direct Odoo/custom SMS endpoint
ODOO_SMS_ENDPOINT=
ODOO_SMS_API_KEY=

# Option B: Odoo JSON-RPC credentials
ODOO_BASE_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=
ODOO_SMS_MODEL=sms.sms
ODOO_SMS_METHOD=create_and_send
