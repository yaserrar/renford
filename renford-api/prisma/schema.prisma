// ============================================================================
// TABLE: Missions
// ============================================================================

model Mission {
    id String @id @default(uuid())

    statut StatutMission @default(en_recherche)

    // Mode de mission (FLEX ou COACH)
    modeMission ModeMission @default(flex)

    //-----------------------------------

    discipline             Discipline    @default(pilates)
    specialitePrincipale   TypeMission   @default(matwork)
    specialitesSecondaires TypeMission[] @default([])

    niveauExperienceRequis NiveauExperience? @default(debutant)

    assuranceObligatoire Boolean  @default(false)
    materielsRequis      String[] @default([])

    description String? @db.Text

    //-----------------------------------

    // Établissement / site
    etablissementId String
    etablissement   Etablissement @relation(fields: [etablissementId], references: [id])

    // Dates et horaires
    dateDebut DateTime
    dateFin   DateTime

    PlageHoraireMission PlageHoraireMission[]

    methodeTarification MethodeTarification @default(horaire)
    tarif               Decimal?            @db.Decimal(10, 2) // Tarif horaire, journalier ou demi-journalier selon la méthode de tarification
    montantHT           Decimal?            @db.Decimal(10, 2) // Montant HT stocké au moment de la création
    montantFraisService Decimal?            @db.Decimal(10, 2) // Frais de service Renford
    montantTTC          Decimal?            @db.Decimal(10, 2) // Total facturé à l'établissement (HT + frais)
    dateDerniereRechercheRenford DateTime? // Dernière exécution de recherche de Renfords

    pourcentageVariationTarif Decimal? @db.Decimal(5, 2) // Pourcentage de variation du tarif en fonction de l'expérience du Renford (ex: +20% pour un expert)

   // Métadonnées
    dateCreation  DateTime @default(now())
    dateMiseAJour DateTime @updatedAt 

    missionsRenford MissionRenford[]
    paiements       Paiement[]

    @@index([etablissementId])
    @@index([statut])
    @@index([modeMission])
    @@index([dateDebut])
    @@index([dateFin])
    @@index([dateDerniereRechercheRenford])
    @@map("missions")
}

// Enums utilisées par Mission
enum ModeMission {
    flex // Missions express/ponctuelles
    coach // Missions longue durée contractualisées
}

enum Discipline {
    pilates
    yoga
    fitness_musculation
    programmes_les_mills
    zumba
    animation_sportive_multisport
    escalade
    boxe_arts_martiaux
    danse
    bien_etre_sport_sante
}

// enum Material {
//     tapis
//     halteres
//     kettlebell
//     elastiques
//     medicine_ball
//     velo_indoor
//     barre
//     autre
// }

enum StatutMission {
    brouillon                  // Mission en préparation, pas encore soumise
    ajouter_mode_paiement      // Aucun moyen de paiement valide, publication bloquée
    en_recherche               // Mission publiée, en recherche de candidatures, pas encore reçu aucune candidature
    candidatures_disponibles   // Un ou plusieurs Renfords ont candidaté (ils ont accepté la mission), en attente de sélection
    attente_de_signature       // Candidature retenue, contrat en attente de signature (l'etablissement a accepté la candidature du Renford, mais le contrat n'est pas encore signé)
    mission_en_cours           // Contrat signé, mission démarrée
    remplacement_en_cours      // Remplacement temporaire suite à une absence
    en_litige                  // Incident ou désaccord nécessitant arbitrage
    mission_terminee           // Mission terminée opérationnellement
    archivee                   // Mission clôturée et archivée
    annulee                    // Mission annulée avant sa clôture normale
}

enum MethodeTarification {
    horaire
    journee
    demi_journee
}

// ============================================================================
// TABLE: Plages horaires de mission (détail jour par jour)
// ============================================================================

model PlageHoraireMission {
    id        String  @id @default(uuid())
    missionId String
    mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

    date       DateTime @db.Date
    heureDebut String // Format "HH:MM"
    heureFin   String // Format "HH:MM"

    dateCreation DateTime @default(now())

    @@index([missionId])
    @@index([date])
    @@map("plages_horaires_mission")
}

// ============================================================================
// TABLE: Association Mission-Renford (assignations, shortlist)
// ============================================================================

model MissionRenford {
    id        String  @id @default(uuid())
    missionId String
    mission   Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

    profilRenfordId String
    profilRenford   ProfilRenford @relation(fields: [profilRenfordId], references: [id])

    // Statut de cette assignation
    statut StatutMissionRenford @default(nouveau)

    // Ordre dans la file d'attente (selection_en_cours)
    ordreShortlist Int?

    // Dates clés
    dateProposition  DateTime  @default(now())
    dateReponse      DateTime?
    dateContratSigne DateTime?

    // Visio pré-mission (mode COACH)
    lienVisio      String?
    dateVisio      DateTime?
    visioEffectuee Boolean   @default(false)

    // Tarif négocié final
    tarifNegocie Decimal? @db.Decimal(8, 2)

    // Signatures des documents contractuels
    signatureContratPrestationRenfordChemin      String?
    signatureContratPrestationEtablissementChemin String?
    signatureAttestationMissionRenfordChemin      String?
    signatureAttestationMissionEtablissementChemin String?

    dateCreation  DateTime @default(now())
    dateMiseAJour DateTime @updatedAt

    @@unique([missionId, profilRenfordId])
    @@index([missionId])
    @@index([profilRenfordId])
    @@index([statut])
    @@map("missions_renfords")
}


// Enum utilisée par MissionRenford
enum StatutMissionRenford {
    nouveau                  // Opportunité nouvellement proposée au Renford, pas encore consultée
    vu                       // Opportunité consultée par le Renford, en attente d'une action
    refuse_par_renford       // Le Renford a refusé l'opportunité ou la proposition
    selection_en_cours       // Le Renford a accepté la mission, en attente de décision de l'établissement (file d'attente ordonnée par ordreShortlist)
    attente_de_signature     // Le Renford est retenu, contrat en préparation ou à signer
    refuse_par_etablissement // Le profil n'est finalement pas retenu par l'établissement
    contrat_signe            // Le contrat est signé, la mission est confirmée pour ce Renford
    mission_en_cours         // La prestation a démarré
    mission_terminee         // La prestation est terminée
    annule                   // L'assignation est annulée avant sa fin normale
}

// ============================================================================
// TABLE: Favoris Renford (établissements qui sauvegardent des profils renford)
// ============================================================================

model FavorisRenford {
    id String @id @default(uuid())

    profilEtablissementId String
    profilEtablissement   ProfilEtablissement @relation(fields: [profilEtablissementId], references: [id], onDelete: Cascade)

    profilRenfordId String
    profilRenford   ProfilRenford @relation(fields: [profilRenfordId], references: [id], onDelete: Cascade)

    dateCreation DateTime @default(now())

    @@unique([profilEtablissementId, profilRenfordId])
    @@index([profilEtablissementId])
    @@index([profilRenfordId])
    @@map("favoris_renford")
}

// ============================================================================
// TABLE: Indisponibilités des renfords
// ============================================================================

enum RepetitionIndisponibilite {
    aucune
    tous_les_jours
    toutes_les_semaines
}

model IndisponibiliteRenford {
    id              String @id @default(uuid())
    profilRenfordId String
    profilRenford   ProfilRenford @relation(fields: [profilRenfordId], references: [id], onDelete: Cascade)

    dateDebut  DateTime @db.Date
    dateFin    DateTime @db.Date
    heureDebut String?  // HH:MM - null si journée entière
    heureFin   String?  // HH:MM - null si journée entière
    journeeEntiere Boolean @default(true)

    repetition RepetitionIndisponibilite @default(aucune)

    dateCreation  DateTime @default(now())
    dateMiseAJour DateTime @updatedAt

    @@index([profilRenfordId])
    @@index([dateDebut, dateFin])
    @@map("indisponibilites_renford")
}

// ============================================================================
// TABLE: Messages de contact (support / contactez-nous)
// ============================================================================

model MessageContact {
    id String @id @default(uuid())

    utilisateurId String
    utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

    email String
    sujet String
    texte String @db.Text

    traite  Boolean   @default(false)
    traiteA DateTime?

    dateCreation  DateTime @default(now())
    dateMiseAJour DateTime @updatedAt

    @@index([utilisateurId])
    @@index([traite])
    @@map("messages_contact")
}

// ============================================================================
// TABLE: Notifications internes (in-app)
// ============================================================================

model Notification {
    id String @id @default(uuid())

    utilisateurId String
    utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

    titre       String
    description String
    source      SourceNotification
    lu          Boolean @default(false)

    // sourceId contient l'identifiant de l'entité source (mission, missionRenford, etc.)
    sourceId String?

    dateCreation  DateTime @default(now())
    dateMiseAJour DateTime @updatedAt

    @@index([utilisateurId])
    @@index([source])
    @@index([lu])
    @@index([source, sourceId])
    @@map("notifications")
}

enum SourceNotification {
    missions
    mission_renfords
    etablissements
    renfords
    paiements
    systeme
}

